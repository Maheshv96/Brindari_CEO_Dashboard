# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # Never expose to the browser

# ── Anthropic (Claude AI) ─────────────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys
# Used for: email personalisation, supplier comparison, reply classification
ANTHROPIC_API_KEY=sk-ant-...

# ── Resend (Transactional Email) ──────────────────────────────────────────────
# Get from: resend.com → API Keys
# Verify your sending domain first (brindari.com)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@brindari.com

# ── AfterShip (Shipment Tracking) ────────────────────────────────────────────
# Get from: admin.aftership.com → API Keys
AFTERSHIP_API_KEY=...

# ── App Config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000   # Change to https://your-domain.com in production
EMAIL_LOGO_URL=                            # Optional: override logo URL in emails (defaults to NEXT_PUBLIC_APP_URL/logo-icon.svg)
CEO_EMAIL=vaishnav.maheshs789@gmail.com    # Weekly report delivery address
NEXT_PUBLIC_USD_TO_INR=83.5               # Update periodically or use a live rate API

# ── Vercel Cron Security ──────────────────────────────────────────────────────
# Generate a random secret: openssl rand -hex 32
# Set the same value in Vercel Dashboard → Environment Variables
CRON_SECRET=change-this-to-a-random-secret
